<h1>Створити нову нотатку</h1>
<form action="/notes" method="POST">
    <input value="<%= note.title %>" type="text" name="title" placeholder="Заголовок" required style="width: 300px;"><br><br>
    <textarea name="content" placeholder="Ваш текст тут..." rows="10" cols="40" required><%= note.content %></textarea><br><br>    
    <button type="submit" style="background: green; color: white;">💾 Зберегти нотатку</button>
</form>
<br>
<a href="/notes">⬅ Назад до списку</a>